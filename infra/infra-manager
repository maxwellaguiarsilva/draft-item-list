#!/usr/bin/env bash

# infra-manager: Manages the project's infrastructure lifecycle
# Usage: ./infra-manager [up|down]

set -e

COMPOSE_FILE="infra/compose.yaml"
SERVICE_NAME="database"

wait_for_db() {
  echo "Waiting for the database to be available at localhost:5432..."
  # Try to connect to the DB (using netcat or similar if available)
  # As we are in a generic environment, we try a simple loop
  until nc -z localhost 5432; do
    echo "Database still not available, waiting..."
    sleep 2
  done
  echo "Database is ready!"
}

case "$1" in
  up)
    echo "Starting infrastructure..."
    docker compose -f "$COMPOSE_FILE" up -d
    wait_for_db
    ;;
  down)
    echo "Stopping infrastructure..."
    docker compose -f "$COMPOSE_FILE" down
    ;;
  *)
    echo "Usage: $0 {up|down}"
    exit 1
    ;;
esac
