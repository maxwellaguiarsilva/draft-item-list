#!/usr/bin/env bash

# infra-manager: Gerencia o ciclo de vida da infraestrutura do projeto
# Uso: ./infra-manager [up|down]

set -e

COMPOSE_FILE="infra/compose.yaml"
SERVICE_NAME="database"

wait_for_db() {
  echo "Aguardando o banco de dados estar disponível em localhost:5432..."
  # Tenta conectar no banco (usando netcat ou similar se disponível)
  # Como estamos em um ambiente genérico, tentamos um loop simples
  until nc -z localhost 5432; do
    echo "Banco ainda não disponível, aguardando..."
    sleep 2
  done
  echo "Banco de dados está pronto!"
}

case "$1" in
  up)
    echo "Subindo infraestrutura..."
    docker compose -f "$COMPOSE_FILE" up -d
    wait_for_db
    ;;
  down)
    echo "Derrubando infraestrutura..."
    docker compose -f "$COMPOSE_FILE" down
    ;;
  *)
    echo "Uso: $0 {up|down}"
    exit 1
    ;;
esac
